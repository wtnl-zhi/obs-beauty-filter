{
  "version": 8,
  "cmakeMinimumRequired": {"major": 3, "minor": 28, "patch": 0},
  "configurePresets": [
    {
      "name": "macos-arm64",
      "displayName": "macOS Apple Silicon",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/macos-arm64",
      "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin"},
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-x64",
      "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows"}
    }
  ],
  "buildPresets": [
    {"name": "macos-arm64", "configurePreset": "macos-arm64", "configuration": "RelWithDebInfo"},
    {"name": "windows-x64", "configurePreset": "windows-x64", "configuration": "RelWithDebInfo"}
  ]
}
